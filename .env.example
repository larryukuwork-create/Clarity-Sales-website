# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server Configuration
PORT=3000
NODE_ENV=production

# Email Service (Resend)
# RESEND_API_KEY: Secure API Token configured in Resend (resend.com) for sending emails
RESEND_API_KEY="re_123456789"
# RESEND_FROM_EMAIL: Sender address (Optional, defaults to raw "onboarding@resend.dev" to avoid sandbox verification constraint)
RESEND_FROM_EMAIL="onboarding@resend.dev"
# RESEND_TO_EMAIL: The target email destination to receive contact form leads (Optional, defaults to accounts@clarityspace.com.au)
RESEND_TO_EMAIL="accounts@clarityspace.com.au"

# Firebase Client (Exposed to Vite)
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# VITE_ADMIN_ACCESS_PASSWORD: General password to gate the private outreach dash
VITE_ADMIN_ACCESS_PASSWORD="Password123."

